# ═══════════════════════════════════════════════════
#  NOSSA AGENDA — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
#  cp .env.example .env
# ═══════════════════════════════════════════════════

# ─── BANCO DE DADOS ─────────────────────────────────
# SQLite local (desenvolvimento)
DATABASE_URL="file:./prisma/dev.db"

# Para PostgreSQL em produção (Supabase, Neon, Railway):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ─── AUTENTICAÇÃO JWT ────────────────────────────────
# Segredo para assinar/verificar tokens JWT
# IMPORTANTE: Use uma string longa e aleatória em produção!
# Gere com: openssl rand -base64 32
JWT_SECRET="seu-segredo-super-secreto-mude-em-producao"

# ─── EMAIL (RESEND) ──────────────────────────────────
# Obtenha sua chave em: https://resend.com/api-keys
# OPCIONAL: Sem esta chave, os links de convite são retornados na API
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Remetente dos emails
# Em dev: use "onboarding@resend.dev" (não precisa de domínio verificado)
# Em produção: use seu domínio verificado no Resend
EMAIL_FROM="Nossa Agenda <onboarding@resend.dev>"

# ─── URL DO APP ──────────────────────────────────────
# URL base usada para gerar links nos emails
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Em produção:
# NEXT_PUBLIC_APP_URL="https://seudominio.com"
