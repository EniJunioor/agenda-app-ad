generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite para desenvolvimento local
  // Para produção (Vercel), use PostgreSQL:
  //   provider = "postgresql"
  //   url      = env("DATABASE_URL")
  //
  // Recomendado: Neon (neon.tech) — PostgreSQL serverless grátis
  // DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require"
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  coupleId     String
  couple       Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Couple {
  id         String          @id @default(cuid())
  name       String
  partner1Id String?
  partner2Id String?
  startDate  String?
  avatar1    String?
  avatar2    String?
  bio        String?
  goalsJson  String?
  users      User[]
  invites    PartnerInvite[]
  events     Event[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model PartnerInvite {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  coupleId  String
  couple    Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Event {
  id        String   @id @default(cuid())
  coupleId  String
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  title     String
  date      String   // ISO YYYY-MM-DD
  time      String   // HH:mm
  category  String
  location  String
  notes     String
  attendees String
  photoUrl  String?
  remindOneDayBefore   Boolean  @default(false)
  remindTwoHoursBefore Boolean  @default(false)
  remindedOneDay       Boolean  @default(false)
  remindedTwoHours     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
